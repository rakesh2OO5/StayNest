<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SatyNest</title>
    <style>
        form{
            display: flex;
            flex-direction: column;
            gap:1rem;
        }
        .input{
            display: flex;
            flex-direction: column;
        }
    </style>
</head>
<body>
    <h2>Edit this Listing :</h2>
    <form method="post" action="/listings/<%= editListing._id %>?_method=PUT">
        <div class="title-input input">
            <label for="title">Title :</label>
            <input type="text" name="title" id="title" value="<%= editListing.title  %>"/>
        </div>
        <div class="desc-input input">
            <label for="description">Description :</label>
            <textarea rows="10" cols="50" name="description" id="description"><%= editListing.description  %></textarea>
        </div>
        <div class="img-input input">
            <label for="image">Image :</label>
            <input type="text" name="image" value="<%= editListing.image  %>" id="image"/>
        </div>
        <div class="price-input input">
            <label for="price">Price :</label>
            <input type="number" name="price" id="price" value="<%= editListing.price%>"/>
        </div>
        <div class="location-input input">
            <label for="location">Location :</label>
            <input type="text" name="location" id="location" value="<%= editListing.location %>"/>
        </div>
        <div class="country-input input">
            <label for="country">Country :</label>
            <input type="text" name="country" id="country" value="<%= editListing.country %>"/>
        </div>
        <div class="submit-btn">
            <button type="submit">Edit</button>
        </div>
    </form>
</body>
</html>