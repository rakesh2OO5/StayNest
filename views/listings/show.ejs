<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-3">
        <h1 class="text-dark">Listing Details</h1>
    </div>
    <div class="card col-6 offset-3">
        <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing-img"></img>
        <div class="card-body">
            <p class="card-text">
                <b><%= listing.title  %></b> <br/> 
                <%= listing.description %> <br/>
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night<br/>
                <%= listing.location %><br>
                <%= listing.country %>
            </p>
        </div>
    </div>
</div>
<div class="btns">
    <a href="/listings/<%= listing._id  %>/edit" class="btn btn-primary col-1 offset-3">Edit</a>
    <form method="post" action="/listings/<%= listing._id  %>?_method=Delete">
        <button type="submit" class="btn btn-success offset-5">Delete</button>
    </form>
</div>

