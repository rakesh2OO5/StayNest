<% layout("/layouts/boilerplate.ejs")  %>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <h2>Create a new Listing</h2>
        <form method="post" action="/listings" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="title" class="form-label">Title :</label>
                <input placeholder="Add a title" class="form-control" type="text" name="title" id="title" required/>
                <div class="valid-feedback">Title looks good!</div>
                <div class="invalid-feedback">Title cannot be empty!</div>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description :</label>
                <textarea class="form-control" name="description" id="description" required></textarea>
                <div class="invalid-feedback">Description cannot be empty!</div>
            </div>
            <div class="mb-3">
                <label for="image" class="form-label">Image:</label>
                <input placeholder="Enter image URL/Link" class="form-control" type="text" name="image" id="image"/>
            </div>
            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label for="price" class="form-label">Price :</label>
                        <input placeholder="999" class="form-control" type="number" name="price" id="price" required/>
                        <div class="invalid-feedback">Price cannot be empty!</div>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="mb-3">
                        <label for="country" class="form-label">Country :</label>
                        <input placeholder="India" class="form-control" type="text" name="country" id="country" required/>
                        <div class="invalid-feedback">Country name cannot be empty!</div>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="location">Location :</label>
                <input placeholder="Karnataka,Bengaluru" class="form-control" type="text" name="location" id="location" required/>
                <div class="invalid-feedback">Location cannot be empty!</div>
            </div>
            <div class="mb-3">
                <button class="btn btn-success mt-3" type="submit">Add</button>
            </div>
        </form>
    </div>
</div>